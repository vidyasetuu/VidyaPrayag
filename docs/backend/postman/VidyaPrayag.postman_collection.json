            "description": "If `announcement_ids` is null/empty, syncs every unsynced announcement. Inserts QUEUED rows in `whatsapp_logs` — no real WhatsApp call yet (mock)."
          }
        }
      ]
    },
    {
      "name": "7. Admissions (jwt)",
      "item": [
        {
          "name": "GET /api/v1/admissions/enquiries/summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/admissions/enquiries/summary", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admissions", "enquiries", "summary"] },
            "description": "Counts (total / new / followup / converted) + 5 most-recent enquiries + an efficiency string like `\"50%\"`."
          }
