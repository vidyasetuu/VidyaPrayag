{
  "info": {
    "_postman_id": "vp-coll-2026-05-22-real-otp",
    "name": "VidyaPrayag API (backend-by-abuzar)",
    "description": "End-to-end Postman collection for the VidyaPrayag Ktor backend.\n\nThis collection assumes:\n• You're running the server on `http://localhost:8080` (see env baseUrl).\n• OTP_DEV_RETURN_CODE=true in your local `.env` — so /send-otp echoes back a `dev_code` field that the test scripts auto-extract into `{{dev_otp}}`.\n• You have set the `phone_number` env var to a real Indian mobile in E.164 (`+919XXXXXXXXX`). The server normalises 10-digit input to +91… too.\n\nRecommended test order (top to bottom):\n  0. Liveness → 1. Landing → 2. App Status\n  3. Auth › Check User (NEW user) → Send OTP → Verify OTP → Signup\n  3. Auth › Check User (EXISTING) → Send OTP → Login\n  4. User Details (with JWT)\n  5. Onboarding (BASIC → BRANDING → ACADEMIC → REVIEW + final submit)\n  6. Announcements → 7. Admissions → 8. User Profile → 9. School / Drawer\n\nEvery request is annotated with a description and (where applicable) a Tests script that chains state via env vars.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "vidyaprayag-backend",
    "_collection_link": ""
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-default the phone number if the user forgot to set it.",
          "if (!pm.environment.get('phone_number')) {",
          "  pm.environment.set('phone_number', '+919999900001');",
          "  console.log('[VP] phone_number was empty — defaulted to +919999900001. Set yours in the env!');",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "0. Liveness",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] },
        "description": "Quick sanity check that the server is running. Expect a plain-text greeting like 'Ktor: Hello, JVM — VidyaPrayag API v1 is live'."
      },
      "response": []
    },
    {
      "name": "1. Landing (public)",
      "item": [
        {
          "name": "GET /api/v1/content/landing",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/content/landing",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","content","landing"]
            },
            "description": "Fetch CMS strings powering the landing/splash screen. Returns `success: true` and a `data` object with `top_tagline`, `parent_info`, `school_info`, `list_of_portals`, etc.  These are seeded by CmsSeed on first cold boot (if APP_SEED_CMS=true)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. App Status (public)",
      "item": [
        {
          "name": "GET /api/v1/config/app-status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "App-Version", "value": "1.0.0" },
              { "key": "Platform", "value": "android" },
              { "key": "Device-Id", "value": "postman-001" },
              { "key": "Accept-Language", "value": "en" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/config/app-status?app_version=1.0.0",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","config","app-status"],
              "query": [{ "key": "app_version", "value": "1.0.0" }]
            },
            "description": "Splash-screen handshake. Returns version_check + maintenance + feature flags JSON from app_config."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Auth (public)",
      "description": "Phone-OTP-first signup/login + email-password fallback. After /verify-otp succeeds, the row in auth_otps is marked verified and /signup or /login will accept this identifier without re-prompting.",
      "item": [
        {
          "name": "Check User (phone)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "var b = pm.response.json();",
                  "pm.test('success', () => b.success === true);",
                  "if (b.data) {",
                  "  pm.environment.set('is_new_user', String(b.data.is_new_user));",
                  "  console.log('[Auth] is_new_user =', b.data.is_new_user, '| auth_method_required =', b.data.auth_method_required);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{phone_number}}\",\n  \"role\": \"school_admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/check-user",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","check-user"]
            },
            "description": "Lookup whether a user exists for this phone/email. Response.data.is_new_user drives whether the client should call /signup or /login next."
          },
          "response": []
        },
        {
          "name": "Send OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "var b = pm.response.json();",
                  "pm.test('success', () => b.success === true);",
                  "var dev = b.data && b.data.dev_code;",
                  "if (dev) {",
                  "  pm.environment.set('dev_otp', dev);",
                  "  console.log('[Auth] dev_otp captured:', dev);",
                  "} else {",
                  "  console.log('[Auth] dev_code not in response — check the server stdout for [MOCK-OTP] log line and set dev_otp manually.');",
                  "}",
                  "if (b.data && b.data.expires_at) {",
                  "  pm.environment.set('otp_expires_at', b.data.expires_at);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{phone_number}}\",\n  \"purpose\": \"login\",\n  \"device_id\": \"postman-001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/send-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","send-otp"]
            },
            "description": "Generates a fresh 6-digit OTP, persists in auth_otps, dispatches via the configured provider (mock prints to server stdout).\n\nIn dev (OTP_DEV_RETURN_CODE=true) the plain code is returned in `data.dev_code`. The test script captures it into `{{dev_otp}}` so the next request can use it.\n\nIndustrial features active on this endpoint:\n  • UPSERT on (identifier, purpose) — resend overwrites the same row\n  • 5 sends/hour rate limit → HTTP 429 OTP_RATE_LIMITED\n  • Hash + salt + pepper persisted, plaintext never stored\n  • Audit trail: ip_address, user_agent, device_id captured\n\nUse `purpose=signup` instead of `login` if you want to keep signup OTPs separate."
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "var b = pm.response.json();",
                  "pm.test('verified', () => b.success === true && b.data && b.data.verified === true);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{phone_number}}\",\n  \"code\": \"{{dev_otp}}\",\n  \"purpose\": \"login\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","verify-otp"]
            },
            "description": "Verifies the OTP. On success, marks auth_otps.is_verified=true so /signup or /login will accept this identifier.\n\nFailure modes (each returns a distinct HTTP code + errorCode so the UI can show precise UX):\n  • 404 OTP_NOT_FOUND — never sent, or already swept\n  • 410 OTP_EXPIRED — 10-minute window elapsed\n  • 423 OTP_LOCKED — 5 wrong attempts; row locked\n  • 401 OTP_INVALID — wrong code, returns `attempts_left`"
          },
          "response": []
        },
        {
          "name": "Verify OTP — WRONG CODE (test brute-force lock)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{phone_number}}\",\n  \"code\": \"000000\",\n  \"purpose\": \"login\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","verify-otp"]
            },
            "description": "Hit this 5 times in a row to confirm the brute-force lock kicks in.\n\nExpected sequence (HTTP 401 each time):\n  1st wrong  → 'Incorrect OTP. Attempts left: 4'\n  2nd        → 'Attempts left: 3'\n  3rd        → 'Attempts left: 2'\n  4th        → 'Attempts left: 1'\n  5th        → HTTP 423 'OTP locked — request a new one'\n\nThen call Send OTP again — it resets attempt_count and is_locked to 0/false (UPSERT behaviour)."
          },
          "response": []
        },
        {
          "name": "Signup (NEW phone user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.code === 201);",
                  "var b = pm.response.json();",
                  "if (b.data) {",
                  "  pm.environment.set('token', b.data.token);",
                  "  pm.environment.set('refresh_token', b.data.refresh_token);",
                  "  pm.environment.set('user_id', b.data.user_id);",
                  "  pm.environment.set('role', b.data.role);",
                  "  console.log('[Auth] Signed up:', b.data.user_id, '/', b.data.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abuzar — Test Admin\",\n  \"identifier\": \"{{phone_number}}\",\n  \"role\": \"school_admin\",\n  \"device_info\": {\n    \"device_id\": \"postman-001\",\n    \"platform\": \"android\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","signup"]
            },
            "description": "Creates a new app_users row.\n\nPHONE SIGNUP requires a verified OTP for this identifier first — call Send OTP + Verify OTP before this.\n\nEMAIL SIGNUP (use an email in `identifier` instead) requires a `password` field; OTP is optional.\n\nOn 201 the test script stores token/refresh_token/user_id/role into env vars for all subsequent authenticated requests."
          },
          "response": []
        },
        {
          "name": "Login (existing phone user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "var b = pm.response.json();",
                  "if (b.success && b.data) {",
                  "  pm.environment.set('token', b.data.token);",
                  "  pm.environment.set('refresh_token', b.data.refresh_token);",
                  "  pm.environment.set('user_id', b.data.user_id);",
                  "  pm.environment.set('role', b.data.role);",
                  "  console.log('[Auth] Logged in:', b.data.user_id, '/', b.data.role, '| profile_completed=', b.data.profile_completed);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{phone_number}}\",\n  \"role\": \"school_admin\",\n  \"otp\": \"{{dev_otp}}\",\n  \"device_info\": {\n    \"device_id\": \"postman-001\",\n    \"platform\": \"android\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","login"]
            },
            "description": "Phone login. Requires a fresh OTP (call Send OTP first to refresh {{dev_otp}}).\n\nFor email login, swap `identifier` to an email and use `password` instead of `otp`:\n```\n{ \"identifier\": \"abc@test.com\", \"password\": \"…\" }\n```\n\nOn success, JWT + refresh token are persisted to env."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "var b = pm.response.json();",
                  "if (b.success && b.data) {",
                  "  pm.environment.set('token', b.data.token);",
                  "  console.log('[Auth] Access token refreshed.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","auth","refresh"]
            },
            "description": "Exchange a refresh token (issued by Signup/Login) for a fresh access token. Refresh tokens are persisted as SHA-256 hashes in user_sessions; revoking a session invalidates them server-side."
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. User Details (jwt)",
      "item": [
        {
          "name": "GET /api/v1/user/details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/user/details",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","user","details"]
            },
            "description": "Returns personal_details (from app_users) + onboarding_details (step status computed from real schools/school_classes data). menu_features driven by app_config.flags JSON.\n\nIf the user has no school yet, onboarding_status=NOT_STARTED and all steps are PENDING/LOCKED."
          },
          "response": []
        }
      ]
    },
    {
      "name": "5. Onboarding (jwt)",
      "description": "BASIC → BRANDING → ACADEMIC → REVIEW. The final REVIEW submission with is_final_submission=true creates a real `schools` row, sets app_users.school_id, and stamps onboarded_at=NOW().",
      "item": [
        {
          "name": "Step BASIC — fetch",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/step?obStepType=BASIC",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","onboarding","step"],
              "query": [{ "key": "obStepType", "value": "BASIC" }]
            },
            "description": "Returns the list of fields to render for the BASIC step + any draft values already saved for this user."
          },
          "response": []
        },
        {
          "name": "Step BASIC — submit drafts",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ob_step_type\": \"BASIC\",\n  \"is_final_submission\": false,\n  \"data_payload\": {\n    \"school_name\": \"Sunrise Public School\",\n    \"board\": \"CBSE\",\n    \"medium\": \"English\",\n    \"school_gender\": \"co_ed\",\n    \"contact_email\": \"admin@sunrise.test\",\n    \"contact_phone\": \"+919876500001\",\n    \"city\": \"Kanpur\",\n    \"district\": \"Kanpur Nagar\",\n    \"state\": \"Uttar Pradesh\",\n    \"pincode\": \"208001\",\n    \"full_address\": \"12 Civil Lines, Kanpur\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","onboarding","submit"]
            },
            "description": "Upserts each (key,value) into school_onboarding_drafts for this user. No school row is created yet — that happens on REVIEW with is_final_submission=true."
          },
          "response": []
        },
        {
          "name": "Step BRANDING — fetch",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/step?obStepType=BRANDING",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","onboarding","step"],
              "query": [{ "key": "obStepType", "value": "BRANDING" }]
            }
          },
          "response": []
        },
        {
          "name": "Step BRANDING — submit drafts",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ob_step_type\": \"BRANDING\",\n  \"is_final_submission\": false,\n  \"data_payload\": {\n    \"logo_url\": \"https://cdn.vidyaprayag.com/test/sunrise-logo.png\",\n    \"brand_color\": \"#FF7A00\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","onboarding","submit"]
            }
          },
          "response": []
        },
        {
          "name": "Step ACADEMIC — fetch",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/step?obStepType=ACADEMIC",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","onboarding","step"],
              "query": [{ "key": "obStepType", "value": "ACADEMIC" }]
            },
            "description": "Returns the list of active school_classes rows for the user's school. Empty until you insert rows (manual SQL — see LOCAL_SETUP_GUIDE Phase 9) or until you complete REVIEW (which doesn't auto-create classes either — you must INSERT them yourself)."
          },
          "response": []
        },
        {
          "name": "Step REVIEW — fetch",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/step?obStepType=REVIEW",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","onboarding","step"],
              "query": [{ "key": "obStepType", "value": "REVIEW" }]
            }
          },
          "response": []
        },
        {
          "name": "Step REVIEW — FINAL submit (creates school row)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "var b = pm.response.json();",
                  "pm.test('onboarding complete', () => b.success && b.data && b.data.is_onboarding_complete === true);",
                  "console.log('[Onboarding] Done. Re-run user/details to see updated state.');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ob_step_type\": \"REVIEW\",\n  \"is_final_submission\": true,\n  \"data_payload\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","onboarding","submit"]
            },
            "description": "When is_final_submission=true on the REVIEW step, the server:\n  1. Reads BASIC + BRANDING drafts for this user\n  2. Creates a new `schools` row (slug = slugify(name) + first 6 chars of UUID)\n  3. Sets app_users.school_id to that new UUID\n  4. Sets app_users.role='school_admin' and profile_completed=true\n  5. Stamps schools.onboarded_at = NOW()\n\nAfter this, GET /user/details returns onboarding_status: COMPLETED."
          },
          "response": []
        },
        {
          "name": "GET /onboarding/academic/class-details (after inserting classes)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/onboarding/academic/class-details?classId=10",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","onboarding","academic","class-details"],
              "query": [{ "key": "classId", "value": "10" }]
            },
            "description": "Returns subjects for one class. Requires you to have inserted rows in school_classes + school_subjects (see LOCAL_SETUP_GUIDE Phase 9)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "6. Announcements (jwt)",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/school/announcements",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","school","announcements"]
            },
            "description": "School scope inferred from app_users.school_id. Super-admins can pass ?school_id=UUID."
          },
          "response": []
        },
        {
          "name": "Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/school/announcements/search?query=ptm",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","school","announcements","search"],
              "query": [{ "key": "query", "value": "ptm" }]
            }
          },
          "response": []
        },
        {
          "name": "Create (POST)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.code === 201);",
                  "var b = pm.response.json();",
                  "if (b.data && b.data.event_id) {",
                  "  pm.environment.set('last_announcement_id', b.data.event_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"PTM\",\n  \"title\": \"Parent-Teacher Meeting — Grade 10\",\n  \"sub_title\": \"Term 1 Performance Review\",\n  \"description\": \"First PTM of the term. Please bring the report book.\",\n  \"event_image\": \"https://cdn.vidyaprayag.com/test/ptm.jpg\",\n  \"date\": \"2026-06-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/school/announcements",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","school","announcements"]
            }
