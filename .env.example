# ===================================================================
# VidyaPrayag Backend — Environment Variables
# Copy this file to `.env` and fill in real values for your environment.
# DO NOT commit `.env` — only `.env.example` is tracked.
# ===================================================================

# -------------------------------------------------------------------
# DATABASE
# -------------------------------------------------------------------
# Supabase Postgres connection string (production / staging).
# Get this from Supabase Dashboard → Project Settings → Database →
# "Connection string" → URI tab. Use the *Transaction Pooler* (port
# 6543) string for serverless or short-lived workloads, or the
# *Session Pooler* (port 5432) string for long-lived JDBC connections
# like this Ktor server.
#
# Accepted forms (the backend normalises all of them):
#   postgres://postgres:[PWD]@db.[REF].supabase.co:5432/postgres
#   postgresql://postgres:[PWD]@db.[REF].supabase.co:5432/postgres
#   jdbc:postgresql://db.[REF].supabase.co:5432/postgres?user=postgres&password=[PWD]
#
# If DATABASE_URL is empty or missing, the server falls back to a
# local SQLite file (./vidyaprayag.db) — useful for offline dev but
# UUID columns get stored as BLOB.
DATABASE_URL=

# -------------------------------------------------------------------
# SERVER
# -------------------------------------------------------------------
# HTTP port the Ktor server listens on. Default is 8080.
PORT=8080

# -------------------------------------------------------------------
# JWT
# -------------------------------------------------------------------
# Long random string used to sign access tokens. MUST be set in
# production. In dev a hardcoded fallback is used (insecure).
# Generate a strong one with:
#   openssl rand -hex 64
JWT_SECRET=change-me-to-a-long-random-string

# Access token lifetime in minutes (default 60).
JWT_ACCESS_MINUTES=60

# Refresh token lifetime in days (default 30).
JWT_REFRESH_DAYS=30

# -------------------------------------------------------------------
# OTP — Industrial-Grade One-Time Password Service
# -------------------------------------------------------------------
# Global pepper added to every OTP hash. Combined with a per-row salt
# this means a database-only dump cannot be used to brute-force OTPs.
# Generate with:
#   openssl rand -hex 32
# IMPORTANT: rotating this invalidates all in-flight OTPs.
OTP_PEPPER=change-me-to-a-long-random-string

# OTP lifetime in minutes (default 10).
OTP_EXPIRY_MINUTES=10

# Max wrong attempts per OTP before the row is locked (default 5).
OTP_MAX_ATTEMPTS=5

# Max OTP sends per identifier in a rolling 1-hour window (default 5).
OTP_MAX_RESENDS_PER_HOUR=5

# When true, the /send-otp response includes a `dev_code` field with
# the plain OTP for Postman/curl testing without SMS infrastructure.
# MUST be false in production.
OTP_DEV_RETURN_CODE=true

# Delivery provider: "mock" (logs to stdout), "msg91", "twilio", "gupshup".
# Only "mock" is implemented in MVP; the others are stubs.
OTP_PROVIDER=mock

# -------------------------------------------------------------------
# SEEDING
# -------------------------------------------------------------------
# When true, the server seeds CMS strings (cms_landing_content +
# app_config) on boot. Safe to leave on — it only inserts missing
# keys, never overwrites existing values. Set false to disable.
APP_SEED_CMS=true
